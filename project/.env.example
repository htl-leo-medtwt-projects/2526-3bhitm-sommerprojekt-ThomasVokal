# Datenbank-Konfiguration für CarFixFast
# WICHTIG: Kopiere diese Datei zu .env und passe die Werte an dein Setup an

# Für Docker-Compose (wie in docker-compose.yml):
DB_HOST=db_server
DB_PORT=3306
DB_NAME=carfixfast
DB_USER=root
DB_PASS=rootpassword

# Wenn du lokal entwickelst (PHP auf dem Host, MySQL auf localhost):
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=carfixfast
# DB_USER=root
# DB_PASS=rootpassword
